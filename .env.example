# ── POSTGRES
POSTGRES_DB=app_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_strong_pass_123

# ── GRAFANA
GRAFANA_PASSWORD=CHANGE_ME_grafana_pass

# ── GOTIFY (push-сервер)
GOTIFY_PASSWORD=CHANGE_ME_gotify_pass
# Цей токен отримаєш після першого входу в Gotify UI (http://localhost:8080)
# Apps → Create App → скопіюй token
GOTIFY_APP_TOKEN=FILL_AFTER_FIRST_LOGIN

# ── TELEGRAM АЛЕРТИ
# Отримай у @BotFather: /newbot
TELEGRAM_BOT_TOKEN=FILL_ME:FILL_ME
# Отримай свій chat_id: напиши боту і перейди на
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=FILL_ME

# ── ZEROTIER
# Зареєструйся на my.zerotier.com → Create Network → скопіюй Network ID
ZEROTIER_NETWORK_ID=FILL_ME_16char_id
